$dark   = rgb(0.3, 0.3, 0.3)
$light  = #FAF9F5
$grey   = #B0AEA5
$accent = #788C5D

style border:
	border-weight = 3
	border-color = rgb(0.4, 0.4, 0.4)
	
root:
	direction = row

	text "input":
		font-size = 24
		editable = true
		share = 3
		padding = 5

	graph "graph":
		background-color = #12121a
		share = 7