
root {
	background-color = #000000
	
	text as main-text {
		content = "abc213"
		height = 100
		share = 1
		text-align = left
	}
	text {
		content = "abc213"
		height = 100
		share = 1
		text-align = center

		on mouse-enter {
			main-text.content = "on a"
		}
	}
	text {
		content = "abc213"
		height = 100
		share = 1
		text-align = right

		on mouse-enter {
			main-text.content = "on b"
		}
	}
}
